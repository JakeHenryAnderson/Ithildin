{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ithildin.local/schemas/runtime-candidate-authorization.schema.json",
  "title": "Ithildin Runtime Candidate Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authorization_id",
    "candidate_id",
    "reviewed_commit",
    "inventory_schema_version",
    "reviewed_inventory_digest",
    "dependency_lock_digest",
    "release_artifact_digest",
    "review_packet_digest",
    "evidence_schema_version",
    "authorized_at",
    "record_hash"
  ],
  "properties": {
    "authorization_id": { "type": "string", "pattern": "^rca_[a-f0-9]{32}$" },
    "candidate_id": { "$ref": "#/$defs/sha256" },
    "reviewed_commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "inventory_schema_version": { "type": "string", "minLength": 1 },
    "reviewed_inventory_digest": { "$ref": "#/$defs/sha256" },
    "dependency_lock_digest": { "$ref": "#/$defs/sha256" },
    "release_artifact_digest": { "$ref": "#/$defs/sha256" },
    "review_packet_digest": { "$ref": "#/$defs/sha256" },
    "evidence_schema_version": { "type": "string", "minLength": 1 },
    "authorized_at": { "type": "string", "format": "date-time" },
    "record_hash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
