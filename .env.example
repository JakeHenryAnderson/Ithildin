# Local demo settings. Copy to .env if you want to override these values.
ITHILDIN_ADMIN_TOKEN=dev-admin-token-change-me
ITHILDIN_ALLOW_DEV_ADMIN_TOKEN=true
ITHILDIN_STORAGE_BACKEND=sqlite
ITHILDIN_POSTGRES_DSN=
ITHILDIN_DB_PATH=var/db/ithildin.sqlite3
ITHILDIN_AUDIT_LOG_PATH=var/logs/audit.jsonl
ITHILDIN_AUDIT_SIGNING_PRIVATE_KEY_PATH=var/keys/audit-ed25519-private.pem
ITHILDIN_AUDIT_SIGNING_PUBLIC_KEY_PATH=var/keys/audit-ed25519-public.pem
ITHILDIN_MANIFEST_DIR=tool-manifests
ITHILDIN_MANIFEST_LOCK_PATH=tool-manifests.lock.json
ITHILDIN_REQUIRE_MANIFEST_LOCK=true
ITHILDIN_MANIFEST_LOCK_SIGNING_PRIVATE_KEY_PATH=var/keys/manifest-lock-ed25519-private.pem
ITHILDIN_MANIFEST_LOCK_SIGNING_PUBLIC_KEY_PATH=var/keys/manifest-lock-ed25519-public.pem
ITHILDIN_MANIFEST_LOCK_SIGNATURE_PATH=var/signatures/tool-manifests.lock.sig.json
ITHILDIN_REQUIRE_SIGNED_MANIFEST_LOCK=false
ITHILDIN_PRINCIPAL_REGISTRY_PATH=principals/local.yaml
ITHILDIN_REQUIRE_KNOWN_PRINCIPALS=true
ITHILDIN_POLICY_PATH=policies/default.yaml
ITHILDIN_POLICY_TESTS_PATH=policies/tests/default.yaml
ITHILDIN_POLICY_ENGINE=yaml
ITHILDIN_OPA_URL=
ITHILDIN_OPA_DECISION_PATH=/v1/data/ithildin/decision
ITHILDIN_OPA_BUNDLE_MANIFEST_PATH=policies/opa/bundle.lock.json
ITHILDIN_WORKSPACE_ROOT=workspaces
ITHILDIN_WORKSPACE_REGISTRY_PATH=workspaces/local.yaml
ITHILDIN_REQUIRE_KNOWN_WORKSPACES=true
ITHILDIN_DEFAULT_WORKSPACE_ID=default
ITHILDIN_LOG_LEVEL=INFO
ITHILDIN_MAX_READ_BYTES=131072
ITHILDIN_MAX_PATCH_BYTES=131072
ITHILDIN_HTTP_ALLOWLIST=
ITHILDIN_HTTP_TIMEOUT_SECONDS=10
ITHILDIN_HTTP_MAX_RESPONSE_BYTES=131072
ITHILDIN_HTTP_MAX_REDIRECTS=3
ITHILDIN_REDACTION_EXTRA_KEYS=
ITHILDIN_REDACTION_EXTRA_PATTERNS=
ITHILDIN_SEARCH_RESULT_LIMIT=100
ITHILDIN_GIT_LOG_LIMIT=20
ITHILDIN_OTEL_ENABLED=false
ITHILDIN_OTEL_SERVICE_NAME=ithildin-api
ITHILDIN_OTEL_CONSOLE_EXPORT=false
ITHILDIN_OTEL_OTLP_ENDPOINT=

# Used when building the local UI container.
VITE_ITHILDIN_API_BASE_URL=http://127.0.0.1:8000

# Non-root container identity. Linux users may set these to their host uid/gid.
ITHILDIN_CONTAINER_UID=10001
ITHILDIN_CONTAINER_GID=10001
