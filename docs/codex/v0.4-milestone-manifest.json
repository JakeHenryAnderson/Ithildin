{
  "manifest_version": "2",
  "program": "v0.4 review closure and evidence maturity",
  "runtime_boundary": "v0.1 local-preview",
  "review_candidate_label": "v0.4 review-closure candidate for the v0.1 local-preview runtime boundary",
  "purpose": "Plan and gate review closure, evidence maturity, diagnostics, and local-preview hardening before any new governed tool-power class is considered.",
  "completed_range": "113-129",
  "planned_range": "130-151",
  "gating_overlay_version": "1",
  "deferred_boundaries": [
    "shell execution",
    "Docker socket access",
    "Kubernetes tools",
    "browser automation",
    "arbitrary HTTP methods, caller-supplied headers, request bodies, cookies, or broad network access",
    "broad filesystem writes, deletes, moves, chmod, archive extraction, or secrets-manager tools",
    "plugin SDK or marketplace",
    "remote hosted MCP gateway",
    "production identity integrations",
    "runtime Postgres",
    "hosted telemetry collectors",
    "managed model serving or LLM proxy workflows"
  ],
  "stop_conditions": [
    "same blocking failure repeats three times",
    "trust-boundary regression",
    "critical or high internal finding",
    "need to change the product boundary",
    "ambiguous release, audit, manifest, signing, or review evidence",
    "inability to return to a clean checkpoint",
    "need for external secrets, privileged host state, or production credentials"
  ],
  "external_review_required_before": [
    "new powerful tool class",
    "production or security-product positioning",
    "remote MCP transport",
    "production identity",
    "runtime Postgres",
    "hosted telemetry",
    "plugin SDK",
    "shell, Docker, Kubernetes, browser, arbitrary HTTP, or broad filesystem write capabilities"
  ],
  "after_each_wave_required_commands": [
    "focused tests for touched surfaces",
    "make release-check",
    "make release-evidence-gate",
    "make review-candidate",
    "make reviewer-findings-check",
    "make review-run-manifest-check",
    "make review-packet-diff-gate OLD=<prior checkpoint> NEW=<current checkpoint>",
    "git status --short"
  ],
  "named_gates": [
    {
      "id": "capability_expansion_gate",
      "name": "Capability Expansion Gate",
      "required_conditions": [
        "make release-check passes",
        "make review-candidate passes",
        "make reviewer-findings-check passes",
        "make review-run-manifest-check passes",
        "make review-packet-diff-gate passes against the prior checkpoint",
        "git status --short is empty",
        "source-review closure matrix has no open critical/high findings",
        "external-review rows relevant to the current boundary are closed or accepted-deferred",
        "accepted risks are linked in threat model or release notes",
        "tool-list changes are absent or covered by a boundary decision",
        "deferred-power list changes are absent or covered by a boundary decision"
      ]
    },
    {
      "id": "tool_surface_invariant_gate",
      "name": "Tool-Surface Invariant Gate",
      "required_conditions": [
        "tool count remains 10",
        "tool names remain unchanged",
        "no manifest additions",
        "no arbitrary HTTP method/header/body/cookie support",
        "no broad filesystem write/delete/move/chmod/archive operation",
        "no new MCP transport",
        "no identity, storage, telemetry, or platform-support boundary change"
      ]
    },
    {
      "id": "evidence_confusion_gate",
      "name": "Evidence-Confusion Gate",
      "required_conditions": [
        "signed evidence is described as local evidence",
        "embedded public key vs trusted public key behavior is explicit",
        "invalid audit chains can be exported only with invalid-status evidence",
        "bundle type, key ID, algorithm, digest, and event order are tested",
        "release evidence distinguishes runtime signing from demo signing",
        "docs do not imply custody, notarization, immutable storage, or official release signing"
      ]
    },
    {
      "id": "ui_admin_no_mutation_gate",
      "name": "UI/Admin No-Mutation Gate",
      "required_conditions": [
        "approval UI uses only existing approve/deny APIs",
        "diagnostics remain read-only",
        "incomplete apply-state display does not introduce repair mutation",
        "copy-evidence actions do not create approvals or tool calls",
        "unauthorized/failure states do not leak secrets or unnecessary local paths"
      ]
    },
    {
      "id": "external_review_closure_gate",
      "name": "External-Review Closure Gate",
      "required_conditions": [
        "every external finding has a structured finding file",
        "every critical/high finding is fixed or formally accepted with rationale",
        "every fix has a verification command",
        "closure matrix state matches finding files",
        "final review packet includes open accepted risks",
        "no production-readiness or security-product wording appears"
      ]
    }
  ],
  "subagent_policy": {
    "role": "internal adversarial reviewer and evidence checker",
    "not_authorized_for": [
      "external source-review closure",
      "production readiness claims",
      "accepting critical or high findings without user/external review"
    ],
    "cadence": "Run at wave gates and convert useful findings into reviewer finding records."
  },
